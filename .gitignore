# Node / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database (never commit your live data to Git)
database.db
database.db-shm
database.db-wal
*.sqlite
*.sqlite3

# Uploaded images (user-generated content, not source code)
uploads/*
# Keep the uploads folder itself but ignore its contents
!uploads/.gitkeep

# Environment variables (API keys, secrets)
.env
.env.local
.env.*.local

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.suo
*.user

# Logs
logs/
*.log

# Build output (if you add a build step later)
dist/
build/
