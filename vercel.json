{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/public/population.html" },
    { "source": "/admin", "destination": "/public/admin.html" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/public/$1" }
  ],
  "cleanUrls": true
}
